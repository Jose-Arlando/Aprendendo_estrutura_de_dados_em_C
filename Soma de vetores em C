#include <stdio.h>
int main()
{
    int acm = 0;
    int vet[10];
    
    for (int i=1;i<=10;i++){
        printf("[%d]: ", i);
        scanf("%d", &vet[i]);
    }
    for (int i=1;i<=10;i++){
        printf("%d + ", vet[i]);
        
        acm = acm + vet[i];
    }
    printf("= ");
    printf("%d", acm);
    return 0;
}
